# ============================================================
# Forus 环境变量模板
# 复制为 .env 并填入真实值（.env 不会被提交到 Git）
# 部署到 Vercel 时，在 Project Settings → Environment Variables 配置这 4 项
# ============================================================

# Supabase 项目地址
SUPABASE_URL=https://your-project.supabase.co

# Supabase publishable / anon key（前端可见，正常公开）
SUPABASE_KEY=your-anon-key

# 服务端共用暗号（前端不可见，你和 TA 约定的口令）
NUXT_PASSPHRASE=your-passphrase

# Cookie 签名密钥（务必保密！生成命令见下方）
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NUXT_AUTH_SECRET=your-random-64-char-secret
